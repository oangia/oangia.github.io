{
  "manifest_version": 3,
  "name": "BCTT Watcher",
  "version": "1.0",
  "host_permissions": [
    "https://finance.vietstock.vn/*",
    "https://trade.vndirect.com.vn/*"
  ],
  "permissions": [
    "storage",
    "webRequest",
    "webRequestBlocking",
    "tabs",
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://finance.vietstock.vn/*",
        "https://trade.vndirect.com.vn/*",
        "https://banggia.vndirect.com.vn/*"
      ],
      "js": ["utils/chart.umd.min.js", "utils/utils.js", "utils/extract.js", "utils/business.js", "utils/dom.js", "stock.js"],
      "run_at": "document_start"
    }
  ]
}
