<form id="save">

<div id="settings" class="flex-1 flex flex-col bg-gray-50">

    <!-- Scrollable Content -->
    <div class="flex-1 overflow-y-auto">
        <div class="max-w-4xl mx-auto px-8 pt-10 pb-32 space-y-16">

            <h1 class="text-2xl font-semibold">Settings</h1>

            <!-- General -->
            <section class="bg-white p-6 rounded shadow space-y-6">
                <h2 class="text-lg font-semibold">General</h2>

                <div class="flex items-center justify-between gap-8">
                    <label class="text-sm font-medium w-1/3">Site Title</label>
                    <input type="text" id="title" name="title" class="w-2/3 border rounded px-4 py-2">
                </div>
            </section>

            <!-- Posts -->
            <section class="bg-white p-6 rounded shadow space-y-6">
                <h2 class="text-lg font-semibold">Posts</h2>

                <div class="flex items-center justify-between gap-8">
                    <label class="text-sm font-medium w-1/3">Posts per page</label>
                    <input type="number" id="posts_per_page" name="posts_per_page" class="w-2/3 border rounded px-4 py-2">
                </div>
            </section>

        </div>
    </div>

    <!-- Sticky Save Bar -->
    <div class="sticky bottom-0 border-t bg-white shadow-[0_-2px_8px_rgba(0,0,0,0.05)]">
        <div class="max-w-4xl mx-auto px-8 py-4 flex justify-between items-center">
            <button class="px-6 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition">
                Save Changes
            </button>
        </div>
    </div>

</div>
</form>
<script>
let id = "698c435e2740414ffeeb0e78";
$.form_edit({
    url: "/api/v1.0.0/options",
    id: id, 
    formId: "save",
    formData: () => {
        const container = document.getElementById("settings");
        const inputs = container.querySelectorAll("input");
        const data = {}
        inputs.forEach(input => {
            data[input.id] = input.value;
            console.log(input.name, input.value);
        });
        console.log(data);
        return data;
    },
    success: (data) => {
        console.log(data);
        toast("Save successfully!", "success");
    }
});
</script>