            <p class="mt-10 text-center text-sm text-gray-500">
                <span id="switchPrompt">Chưa có tài khoản?</span>
                <button type="button" onclick="toggleForms()" class="font-semibold leading-6 text-teal-600 hover:text-teal-500" id="switchButton">Đăng ký ngay</button>
            </p>
        </div>
    </div>
    
    <script>
        let apiUrl = "https://api-534394830199.asia-southeast1.run.app";
        let isLoginForm = true;

        function toggleForms() {
            const loginForm = document.getElementById('loginForm');
            const registerForm = document.getElementById('registerForm');
            const switchPrompt = document.getElementById('switchPrompt');
            const switchButton = document.getElementById('switchButton');
            const toggleText = document.getElementById('toggleText');

            if (isLoginForm) {
                // Show register form
                loginForm.classList.add('hidden');
                registerForm.classList.remove('hidden');
                switchPrompt.textContent = 'Đã có tài khoản?';
                switchButton.textContent = 'Đăng nhập';
                isLoginForm = false;
            } else {
                // Show login form
                registerForm.classList.add('hidden');
                loginForm.classList.remove('hidden');
                switchPrompt.textContent = 'Chưa có tài khoản?';
                switchButton.textContent = 'Đăng ký ngay';
                isLoginForm = true;
            }
        }

        function togglePassword(inputId) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
            } else {
                input.type = 'password';
            }
        }

        // Login form submission
        onClick('login', () => {
            const formData = {
                email: document.getElementById('loginEmail').value,
                password: document.getElementById('loginPassword').value
            };
            apiRequest({
                url: apiUrl + "/api/v1.0.0/auth/login",
                method: "POST",
                headers: {
                    'Content-Type': 'application/json',
                },
                data: JSON.stringify(formData),
                onSuccess: (data) => {
                    showToast('Đăng nhập thành công!', 'success');
                    Auth.login(data.token);
                },
                onFail: (data) => {
                    console.log('Data:', data);
                }
            });
        });
        // Register form submission
        onClick('register', () => {
            const password = document.getElementById('registerPassword').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            // Validate password match
            if (password !== confirmPassword) {
                showToast('Mật khẩu xác nhận không khớp!', 'error');
                return;
            }

            const formData = {
                email: document.getElementById('registerEmail').value,
                password: password
            };

            apiRequest({
                url: apiUrl + "/api/v1.0.0/auth/register",
                method: "POST",
                headers: {
                    'Content-Type': 'application/json',
                },
                data: JSON.stringify(formData),
                onSuccess: (data) => {
                    showToast('Đăng ký thành công!', 'success');
                    
                },
                onFail: (data) => {
                    console.log('Data:', data);
                }
            });
        });
    </script>
