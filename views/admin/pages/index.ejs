<div class="max-w-5xl mx-auto bg-white shadow-lg rounded-xl p-6 mt-6">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Pages</h1>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600">Title</th>
                    <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600">Action</th>
                </tr>
            </thead>
            <tbody id="table" class="divide-y divide-gray-200 bg-white">
                <!-- Users will render here -->
            </tbody>
        </table>
    </div>

</div>

<script>
$.table({
    url: "https://api-534394830199.asia-southeast1.run.app/api/v1.0.0/pages",
    table: "table",
    limit: 10,
    renderItem: (item) => {
        return `
            <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 text-sm text-gray-800 font-medium">
                    ${item.title || "-"}<br/>
                    <i>${item.published_at ? new Date(item.published_at).toLocaleDateString() : "-"}</i>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                    
                </td>
            </tr>
        `;
    }
});
</script>