<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<form id="publish">
<div class="max-w-7xl mx-auto">
    <div class="flex-1 overflow-y-auto custom-scrollbar">
        <div class="max-w-7xl mx-auto">
            <div class="flex">

                <!-- Main Editor Area -->
                <div class="flex-1 border-r border-gray-200 flex flex-col h-[calc(100vh-60px)]">
                    
                    <div class="p-6 flex flex-col flex-1 min-h-0">
                        
                        <!-- Title Input -->
                        <div class="mb-6">
                            <input 
                                id="title"
                                name="title"
                                class="w-full text-2xl font-normal text-gray-800 placeholder:text-gray-400 border-none focus:outline-none focus:ring-0 p-0" 
                                placeholder="Title" 
                                type="text"
                            />
                        </div>

                        <!-- Quill Editor -->
                        <div id="editor" class="flex-1 min-h-0"></div>

                    </div>
                </div>

                <!-- Right Sidebar -->
                <aside class="w-80 bg-gray-50 p-4 overflow-y-auto"
       style="max-height: calc(100vh - 60px);">

   <!-- Bottom Publish Button -->
    <div class="pt-4">
        <button 
            class="w-full px-6 py-2 text-sm font-medium bg-orange-500 text-white rounded hover:bg-orange-600 transition-colors"
        >
            Publish
        </button>
    </div>
    <!-- Top content (if any future settings) -->
    <div class="flex-1"></div>
</aside>

            </div>
        </div>
    </div>
</div>
</form>
<script>
    $.form({
        url: apiUrl + '/api/v1.0.0/pages',
        formId: "publish",
        formData: () => {
            return {
                title: document.getElementById('title').value.trim(),
                content: quill.getText().trim(),
                slug: generateSlug(document.getElementById('title').value.trim()),
                published_at: Date.now()
            }
        },
        success: () => {
            location.href = "/admin/pages";
        }
    });

// Quill init
const quill = new Quill('#editor', {
    theme: 'snow',
    placeholder: 'Tell your story...',
    modules: {
        toolbar: [
            [{ header: [1, 2, 3, false] }],
            ['bold', 'italic', 'underline', 'strike'],
            ['blockquote', 'code-block'],
            [{ list: 'ordered' }, { list: 'bullet' }],
            ['link', 'image'],
            ['clean']
        ]
    }
});

function generateSlug(text) {
    return text
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/[\s_-]+/g, '-')
        .replace(/^-+|-+$/g, '');
}
</script>