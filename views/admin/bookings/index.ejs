<div class="max-w-5xl mx-auto bg-white shadow-lg rounded-xl p-6 mt-6">

    <div class="flex justify-between items-center mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Bookings</h1>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full border border-gray-200 rounded-lg overflow-hidden">
            <thead class="bg-gray-50">
                <tr>
                    <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600">Tên</th>
                    <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600">Sđt</th>
                    <th class="px-4 py-3 text-left text-sm font-semibold text-gray-600">
                        <svg xmlns="http://www.w3.org/2000/svg"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            class="w-6 h-6 text-yellow-400">
                        <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z"/>
                        </svg>
                    </th>
                </tr>
            </thead>
            <tbody id="table" class="divide-y divide-gray-200 bg-white">
                <!-- Users will render here -->
            </tbody>
        </table>
    </div>

</div>

<script>
$.table({
    url: "https://api-534394830199.asia-southeast1.run.app/api/v1.0.0/bookings",
    table: "table",
    limit: 10,
    renderItem: (item) => {
        return `
            <tr class="hover:bg-gray-50">
                <td class="px-4 py-3 text-sm text-gray-800 font-medium">
                    ${item.name || "-"}<br/>
                    <i>${item.published_at ? new Date(item.published_at).toLocaleDateString() : "-"}</i>
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                    ${item.phone}
                </td>
                <td class="px-4 py-3 text-sm text-gray-500">
                    
                </td>
            </tr>
        `;
    }
});
</script>