        <style type="text/tailwindcss"> body {
            font-family: 'Inter', sans-serif;
        }
        ::-webkit-scrollbar {
            width: 6px;
        }
        ::-webkit-scrollbar-track {
            background: #f1f5f9;
        }
        ::-webkit-scrollbar-thumb {
            background: #cbd5e1;
            border-radius: 10px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #0d9488;
        }
        .form-input-custom {
            @apply w-full bg-white border border-slate-200 rounded-lg px-4 py-3 focus:ring-2 focus:ring-primary/20 focus:border-primary outline-none transition-all text-slate-700 placeholder:text-slate-400;
        }
        .sidebar-link {
            @apply flex items-center gap-3 px-4 py-3 text-slate-500 hover:text-primary hover:bg-slate-50 transition-colors rounded-lg;
        }
        .sidebar-link-active {
