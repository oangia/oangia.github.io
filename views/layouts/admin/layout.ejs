            <span class="material-icons text-2xl">help_outline</span>
        </button> -->
        <script>
            document.getElementById('logout').addEventListener('click', function (e) {
                e.preventDefault();
                Auth.logout();
            });
            document.querySelectorAll(".user-email").forEach(el => {
                el.textContent = Auth.user().email;
            });
        </script>
    </body>
